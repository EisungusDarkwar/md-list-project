---
// 布局组件
export interface Props {
  title?: string;
  description?: string;
}

const { title = "文章列表", description = "展示所有Markdown文件" } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <header>
      <h1>📝 我的文章库</h1>
    </header>
    <main>
      <slot />
    </main>
  </div>
</body>
</html>